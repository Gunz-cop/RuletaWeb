---
interface Tool {
  id: string;
  name: string;
  desc: string;
  href: string;
  status: 'active' | 'coming-soon';
  icon: 'wheel' | 'coin' | 'dice' | 'rps' | 'secret-friend' | 'numbers' | 'teams' | 'oracle' | 'timer';
}

interface Props {
  activeToolId?: string;
}

const { activeToolId } = Astro.props;

const tools: Tool[] = [
  {
    id: 'ruleta',
    name: 'Ruleta de Decisión Aleatoria',
    desc: 'Crea tu propia ruleta personalizada con opciones, gírala y deja que el azar elija por ti de forma divertida y rápida.',
    href: '/#ruleta',
    status: 'active',
    icon: 'wheel'
  },
  {
    id: 'moneda',
    name: 'Lanzar Moneda',
    desc: 'Cara o cruz al instante con físicas en 3D. Elige entre moneda clásica, pirata o forajida con un agujero de bala real.',
    href: '/moneda',
    status: 'active',
    icon: 'coin'
  },
  {
    id: 'dados',
    name: 'Lanzar Dados',
    desc: 'Lanza 1, 2 o 3 dados a la vez. Elige entre las temáticas Casino de Las Vegas, Calabozos y Dragones (D20) o Yu-Gi-Oh.',
    href: '/dados',
    status: 'active',
    icon: 'dice'
  },
  {
    id: 'piedra-papel-tijera',
    name: 'Piedra, Papel o Tijera',
    desc: 'El clásico juego de manos contra la IA o un amigo. Animaciones dinámicas, contador de victorias y dos modos de juego.',
    href: '/piedra-papel-tijera',
    status: 'active',
    icon: 'rps'
  },
  {
    id: 'amigo-secreto',
    name: 'Amigo Secreto Online',
    desc: 'Organiza tu sorteo de regalos sin papelitos y 100% privado. Genera enlaces instantáneos para compartir.',
    href: '/amigo-secreto',
    status: 'active',
    icon: 'secret-friend'
  },
  {
    id: 'numeros',
    name: 'Generador de Números',
    desc: 'Genera uno o varios números aleatorios en un rango personalizado, con opción de evitar duplicados.',
    href: '/numeros',
    status: 'active',
    icon: 'numbers'
  },
  {
    id: 'equipos',
    name: 'Generador de Equipos',
    desc: 'Divide una lista de nombres de manera equilibrada en múltiples equipos aleatorios de forma instantánea.',
    href: '/equipos',
    status: 'active',
    icon: 'teams'
  },
  {
    id: 'si-o-no',
    name: 'Sí o No (Oráculo)',
    desc: 'Pregunta al oráculo místico y obtén una respuesta binaria directa acompañada de una animación de bola 8.',
    href: '/si-o-no',
    status: 'active',
    icon: 'oracle'
  },
  {
    id: 'temporizador',
    name: 'Temporizador Aleatorio',
    desc: 'Establece un rango de tiempo y deja que termine en un segundo aleatorio. Ideal para juegos y retos.',
    href: '/temporizador',
    status: 'active',
    icon: 'timer'
  }
];

// Reordering to put active one first or filtering out active if desired.
// Let's filter out the activeToolId from being showing if we want to show "related tools" only,
// or show all. For the hub grid on home, we show all.
---

<div class="hub-grid">
  {tools.map((tool, index) => {
    // Escalonar delays usando el índice
    const delayClass = `reveal-delay-${(index % 6) + 1}`;
    const isCurrent = tool.id === activeToolId;

    return (
      <a 
        href={tool.status === 'active' ? tool.href : '#'} 
        class={`hub-card reveal-scale ${delayClass} ${isCurrent ? 'current-active' : ''}`}
        id={`card-${tool.id}`}
        style={tool.status !== 'active' ? 'cursor: not-allowed; opacity: 0.7;' : 'text-decoration: none;'}
      >
        <div class="hub-card-icon">
          {tool.icon === 'wheel' && (
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="6"/>
              <circle cx="12" cy="12" r="2"/>
              <line x1="12" y1="2" x2="12" y2="22"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
            </svg>
          )}
          {tool.icon === 'coin' && (
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="6"/>
              <path d="M12 8a2.5 2.5 0 0 1 2 4.5 2.5 2.5 0 0 1-4.5-2.5A2.5 2.5 0 0 1 12 8z"/>
            </svg>
          )}
          {tool.icon === 'dice' && (
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="3" ry="3"/>
              <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor" stroke="none"/>
              <circle cx="15.5" cy="8.5" r="1.5" fill="currentColor" stroke="none"/>
              <circle cx="8.5" cy="15.5" r="1.5" fill="currentColor" stroke="none"/>
              <circle cx="15.5" cy="15.5" r="1.5" fill="currentColor" stroke="none"/>
              <circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/>
            </svg>
          )}
          {tool.icon === 'rps' && (
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              <path d="M5 15a7 7 0 0 0 14 0v-3a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v3z"/>
              <line x1="9" y1="12" x2="9" y2="16"/>
              <line x1="15" y1="12" x2="15" y2="16"/>
            </svg>
          )}
          {tool.icon === 'secret-friend' && (
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 12 20 22 4 22 4 12"/>
              <rect x="2" y="7" width="20" height="5"/>
              <line x1="12" y1="22" x2="12" y2="7"/>
              <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/>
              <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
            </svg>
          )}
          {tool.icon === 'numbers' && (
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 22V4c0-.5.2-1 .6-1.4C5 2.2 5.5 2 6 2h12c.5 0 1 .2 1.4.6.4.4.6.9.6 1.4v18l-5-4-5 4-5-4-5 4z"/>
              <path d="M9 7h6M9 11h6"/>
            </svg>
          )}
          {tool.icon === 'teams' && (
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          )}
          {tool.icon === 'oracle' && (
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              <path d="M2 12h20"/>
            </svg>
          )}
          {tool.icon === 'timer' && (
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
              <path d="M12 2v2"/>
            </svg>
          )}
        </div>
        <h3>{tool.name}</h3>
        <p>{tool.desc}</p>
        <span class={`hub-card-badge ${tool.status === 'active' ? 'active' : ''}`}>
          {tool.status === 'active' ? '⚡ Disponible' : '⌛ Próximamente'}
        </span>
      </a>
    );
  })}
</div>

<style>
  .hub-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    width: 100%;
  }

  .hub-card {
    background: var(--bg-surface);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-lg);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.35s ease,
                box-shadow 0.35s ease;
  }

  .hub-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--accent-gradient);
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .hub-card:hover {
    transform: translateY(-4px);
    border-color: rgba(0, 229, 255, 0.25);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3),
                0 0 20px rgba(0, 229, 255, 0.08);
  }

  .hub-card:hover::before {
    opacity: 1;
  }

  .hub-card.current-active {
    border-color: rgba(179, 102, 255, 0.3);
    box-shadow: 0 4px 20px rgba(179, 102, 255, 0.05);
    pointer-events: none; /* No clickable if you are already on that page */
  }

  .hub-card.current-active::before {
    opacity: 0.5;
    background: linear-gradient(135deg, #b366ff 0%, #00e5ff 100%);
  }

  .hub-card-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    background: rgba(0, 229, 255, 0.08);
    border: 1px solid rgba(0, 229, 255, 0.12);
    flex-shrink: 0;
  }

  .hub-card-icon svg {
    width: 26px; height: 26px;
    stroke: var(--accent-cyan);
    stroke-width: 1.8;
    fill: none;
  }

  /* Color variation for some icons to make the hub look premium and lively */
  .hub-card:nth-child(even) .hub-card-icon {
    background: rgba(179, 102, 255, 0.08);
    border-color: rgba(179, 102, 255, 0.12);
  }
  .hub-card:nth-child(even) .hub-card-icon svg {
    stroke: var(--accent-purple);
  }

  .hub-card h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0;
  }

  .hub-card p {
    color: var(--text-secondary);
    font-size: 0.88rem;
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }

  .hub-card-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text-secondary);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    width: fit-content;
  }

  .hub-card-badge.active {
    background: rgba(0, 229, 255, 0.08);
    border: 1px solid rgba(0, 229, 255, 0.18);
    color: var(--accent-cyan);
  }

  .hub-card:nth-child(even) .hub-card-badge.active {
    background: rgba(179, 102, 255, 0.08);
    border-color: rgba(179, 102, 255, 0.18);
    color: var(--accent-purple);
  }
</style>
