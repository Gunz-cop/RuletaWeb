---
const tools = [
  { name: 'Ruleta', href: '/' },
  { name: 'Moneda', href: '/moneda' },
  { name: 'Dados', href: '/dados' },
  { name: 'Piedra, Papel o Tijera', href: '/piedra-papel-tijera' },
  { name: 'Amigo Secreto', href: '/amigo-secreto' },
  { name: 'Números', href: '/numeros' },
  { name: 'Equipos', href: '/equipos' },
  { name: 'Sí o No', href: '/si-o-no' },
  { name: 'Temporizador', href: '/temporizador' },
];

const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <div class="footer-links">
      {tools.map(tool => (
        <a href={tool.href}>{tool.name}</a>
      ))}
      <a href="/blog">Blog</a>
      <a href="/sobre">Sobre</a>
    </div>
    <div class="footer-legal-links" style="margin-top: 0.75rem; display: flex; justify-content: center; gap: 1.5rem; flex-wrap: wrap;">
      <a href="/contacto" style="color: var(--text-tertiary); font-size: 0.85rem; text-decoration: none; transition: var(--transition);">Contacto</a>
      <a href="/politica-privacidad" style="color: var(--text-tertiary); font-size: 0.85rem; text-decoration: none; transition: var(--transition);">Política de Privacidad</a>
      <a href="/terminos-condiciones" style="color: var(--text-tertiary); font-size: 0.85rem; text-decoration: none; transition: var(--transition);">Términos y Condiciones</a>
    </div>
    <p style="margin-top: 1.5rem;">&copy; {year} <strong>decídelo.app</strong> — Hub de Herramientas de Decisión Aleatoria.</p>
    <p>Creado con ❤️ para resolver tus dilemas. 100% privado y sin registro.</p>
  </div>
</footer>

<style>
  .footer-legal-links a:hover {
    color: var(--text-secondary) !important;
  }
</style>
