    font-family: 'Outfit', sans-serif;
    font-size: 1.8rem;
    font-weight: 800;
    line-height: 1;
  }

  .score-value.wins { color: var(--accent-cyan); }
  .score-value.losses { color: var(--accent-danger); }
  .score-value.ties { color: var(--accent-purple); }

  /* ===== BOTONES DE ELECCIÓN ===== */
  .choices-row {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .choice-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    background: var(--bg-surface-alt);
    border: 2px solid var(--card-border);
    border-radius: var(--radius-md);
    padding: 1.2rem 1.5rem;
    cursor: pointer;
    transition: var(--transition);
    color: var(--text-primary);
    min-width: 100px;
  }

  .choice-btn:hover:not(:disabled):not(.locked) {
    border-color: rgba(0, 229, 255, 0.4);
    background: var(--bg-surface-hover);
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0, 229, 255, 0.1);
  }

  .choice-btn.selected {
    border-color: transparent;
    background: linear-gradient(var(--bg-surface-alt), var(--bg-surface-alt)) padding-box,
