---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import HubGrid from '../components/HubGrid.astro';
import SeoArticle from '../components/SeoArticle.astro';

const title = 'Organizador de Amigo Secreto Online — Sorteo 100% Privado | Decídelo.app';
const description = 'Organiza tu sorteo de amigo secreto online 100% privado y sin base de datos. Sin registros ni descargas. Genera enlaces secretos para enviar por WhatsApp.';
const keywords = 'amigo secreto online, sorteo amigo secreto, amigo invisible virtual, sorteo sin registro, amigo secreto whatsapp, amigo secreto serverless, tomar decisiones, azar';

const schemaLD = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "@id": "https://decidelo.app/amigo-secreto#webapp",
      "name": "Organizador de Amigo Secreto Online — Decídelo.app",
      "description": "Herramienta online para realizar sorteos de amigo secreto de forma 100% privada, sin base de datos y utilizando ciclos hamiltonianos matemáticamente seguros.",
      "url": "https://decidelo.app/amigo-secreto",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript",
      "softwareVersion": "2.0.0",
      "inLanguage": "es",
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      },
      "image": "https://decidelo.app/blog/amigo-secreto.png",
      "screenshot": "https://decidelo.app/blog/amigo-secreto.png",
      "publisher": {
        "@type": "Organization",
        "@id": "https://decidelo.app/#organization",
        "name": "Decídelo.app",
        "url": "https://decidelo.app/",
        "logo": {
          "@type": "ImageObject",
          "url": "https://decidelo.app/favicon.svg"
        }
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://decidelo.app/amigo-secreto#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": "https://decidelo.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Amigo Secreto",
          "item": "https://decidelo.app/amigo-secreto"
        }
      ]
    }
  ]
};
---

<Layout title={title} description={description} keywords={keywords} schemaLD={schemaLD} showHomeHeader={false}>
  <main class="container">
    
    <!-- PANTALLA DEL ORGANIZADOR (Por defecto) -->
    <div id="organizer-screen" style="width: 100%; display: block;">
      
      <!-- Hero Section -->
      <section class="hero slide-up delay-1">
        <h1>Amigo Secreto <span class="gradient-text">Online</span></h1>
        <p>Organiza tu intercambio de regalos de forma 100% privada, instantánea y serverless. Genera enlaces secretos para enviar por WhatsApp.</p>
      </section>

      <AdSlot position="top" />

      <!-- App Card -->
      <section class="app-card slide-up delay-2">
        
        <!-- Tabs para métodos de entrada -->
        <div class="tabs">
          <button class="tab-btn active" data-tab="tab-manual">Ingreso Manual</button>
          <button class="tab-btn" data-tab="tab-csv">Cargar Archivo CSV</button>
        </div>

        <!-- Tab Ingreso Manual -->
        <div id="tab-manual" class="tab-content active">
          <textarea id="participants-textarea" placeholder="Escribe o pega los nombres (uno por línea)&#10;Ejemplos:&#10;Carlos&#10;María, maria@email.com&#10;Juan, +5215512345678" aria-label="Lista de participantes"></textarea>
          <div class="input-hint">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
            </svg>
            Puedes ingresar solo nombres o usar el formato "Nombre, WhatsApp/Correo".
          </div>
        </div>

        <!-- Tab Carga CSV -->
        <div id="tab-csv" class="tab-content">
          <div class="drag-zone" id="csv-dropzone" role="button" aria-label="Cargar archivo CSV">
            <svg viewBox="0 0 24 24" width="40" height="40" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
            <p>Arrastra tu archivo CSV aquí o <span>haz clic para buscar</span></p>
            <input type="file" id="csv-file-input" accept=".csv" style="display: none;">
          </div>
          <div class="input-hint">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
            </svg>
            El CSV debe contener el nombre en la primera columna y el contacto en la segunda columna.
          </div>
        </div>

        <!-- Botones de Procesamiento y Contador -->
        <div class="list-header">
          <h3>Participantes agregados</h3>
          <span class="counter-badge" id="participants-count">0 participantes</span>
        </div>

        <div class="participants-tags" id="participants-tags-container">
          <span class="tag-empty">Ninguno aún. Agrega nombres arriba para empezar.</span>
        </div>

        <!-- Botón de Sorteo -->
        <button class="primary-btn" id="btn-draw" style="width: auto; max-width: 320px; margin: 0 auto; display: block;" disabled>REALIZAR SORTEO</button>

        <!-- Matriz de Validación Anónima -->
        <div class="validation-section" id="validation-section">
          <div class="validation-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            Matriz de Validación Anónima
          </div>
          <p class="validation-desc">
            Esta matriz valida matemáticamente que el sorteo forma un <strong>Ciclo Hamiltoniano Cerrado</strong> (todos regalan a alguien y todos reciben un regalo sin subgrupos ni islas aisladas). Se asigna un identificador numérico aleatorio para ocultar los nombres y mantener la sorpresa absoluta.
          </p>
          <table class="matrix-table">
            <thead>
              <tr>
                <th>Giver (Emisor)</th>
                <th>Vínculo</th>
                <th>Receiver (Receptor)</th>
              </tr>
            </thead>
            <tbody id="matrix-tbody">
              <!-- Rellenado dinámicamente -->
            </tbody>
          </table>
        </div>

      </section>

      <!-- Resultados del Sorteo -->
      <section class="app-card results-section" id="results-section">
        <h2>Enlaces de Amigo Secreto Generados</h2>
        <p style="color: var(--text-secondary); text-align: center; margin-bottom: 2rem; font-size: 0.95rem;">
          Copia los enlaces individuales o envíalos directamente por WhatsApp a cada participante.
        </p>
        <div class="links-list" id="links-list-container">
          <!-- Rellenado dinámicamente -->
        </div>
      </section>

    </div>

    <!-- PANTALLA DE REVELACIÓN INTERACTIVA (Cuando hay ?revelar en URL) -->
    <div id="reveal-screen" class="slide-up delay-1" style="display: none; flex-direction: column; align-items: center; text-align: center; width: 100%; max-width: 500px; margin: auto 0; padding: 2.5rem 1.5rem;">
      <div class="invite-box">
        <h2>Tu Amigo Secreto 🎁</h2>
        <p>Has sido invitado al juego de intercambio. Haz clic sobre la caja de regalo para descubrir a quién te toca regalar.</p>
      </div>

      <div class="gift-container" id="gift-container" role="button" aria-label="Caja de regalo. Pulsa para abrir.">
        <div class="gift-box" id="gift-box">
          <div class="gift-bow"></div>
          <div class="gift-lid"></div>
          <div class="gift-ribbon-v"></div>
          <div class="gift-ribbon-h"></div>
          <div class="gift-body"></div>
          <div class="secret-card">
            <span class="card-label">Te toca regalar a:</span>
            <span class="card-value" id="revealed-name">Cargando...</span>
          </div>
        </div>
      </div>
    </div>

  </main>

  <div class="toast" id="toast-message">Copiado al portapapeles</div>

  <SeoArticle title="¿Cómo organizar un sorteo de Amigo Secreto transparente y 100% privado?">
    <p>Organizar el tradicional juego del <strong>Amigo Secreto</strong> (o Amigo Invisible) suele implicar coordinar papelitos físicos, lidiar con la auto-asignación indeseada, o delegar en servicios web centralizados que guardan listas de correos en bases de datos con fines publicitarios. En la era digital, la privacidad es fundamental.</p>
    
    <p>Nuestra herramienta de <strong>Amigo Secreto Online</strong> ofrece un enfoque revolucionario <strong>Serverless</strong> (sin base de datos). Toda la lógica, el barajado de participantes y la encriptación se realizan en el procesador local de tu navegador. Esto garantiza que las identidades nunca viajen a un servidor externo, ofreciendo confidencialidad y confidencialidad absolutas.</p>

    <h2>La Lógica del Ciclo Hamiltoniano: Evitando el Bloqueo y las "Islas"</h2>
    <p>Un problema común en los sorteos automáticos es la fragmentación. Por ejemplo, en un grupo de seis personas, si A regala a B, B regala a A, y C, D, E, F hacen lo propio por separado, se crean dos grupos totalmente aislados (llamados subciclos o "islas"). Esto devalúa el juego grupal.</p>
    <p>Para solucionar esto de manera científica, implementamos un <strong>algoritmo de Ciclo Hamiltoniano</strong>. Este algoritmo toma la red de participantes y genera una sola trayectoria continua y cerrada que conecta a todos los nodos una sola vez de forma lineal. De esta manera:</p>
    <ul>
      <li>Nadie puede auto-asignarse (cero posibilidades de regalarse a sí mismo).</li>
      <li>Toda la mesa participa en una cadena común perfecta.</li>
      <li>El sorteo queda validado matemáticamente antes de distribuir las cartas de regalo.</li>
    </ul>

    <h2>Matriz de Validación Anónima: Transparencia sin Revelación</h2>
    <p>¿Cómo puede el organizador confiar en que el sorteo es válido si no puede ver los resultados? A través de la <strong>Matriz de Validación Anónima</strong>. Esta funcionalidad asigna identificadores numéricos secretos a cada participante (por ejemplo, <em>Participante #4</em>). De este modo, la tabla visual comprueba el cierre completo de la cadena hamiltoniana y confirma el sorteo sin revelar la sorpresa.</p>

    <h2>Cifrado Local Seguro en la URL</h2>
    <p>Una vez completado el sorteo, la aplicación codifica el resultado en base64 junto con una clave de ofuscación de tipo XOR. Al pulsar en compartir por WhatsApp, el enlace de invitación contiene de forma encriptada solo el nombre del destinatario del regalo. Cuando este abre su enlace único, su navegador realiza el descifrado local instantáneo para revelárselo mediante una experiencia de desempaquetado premium.</p>
  </SeoArticle>

  <AdSlot position="bottom" />

  <section class="hub-section container">
    <div class="section-header reveal">
      <div class="section-tag">🧰 Caja de Herramientas</div>
      <h2 class="section-heading">Prueba otras herramientas de decisión</h2>
    </div>
    <HubGrid activeToolId="amigo-secreto" />
  </section>

  <script src="../scripts/amigo-secreto.js"></script>
</Layout>

<style>
  main {
    padding: 3rem 0;
  }

  /* App Card específico */
  .app-card {
    width: 100%;
    background: var(--bg-surface);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    box-shadow: var(--shadow-lg);
    position: relative;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .app-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--accent-gradient);
  }

  /* Tabs */
  .tabs {
    display: flex;
    border-bottom: 1px solid var(--card-border);
    margin-bottom: 1.5rem;
    gap: 1.5rem;
  }

  .tab-btn {
    background: transparent;
    border: none;
    color: var(--text-secondary);
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 1.05rem;
    padding: 0.8rem 0;
    cursor: pointer;
    position: relative;
    transition: var(--transition);
  }

  .tab-btn:hover {
    color: #ffffff;
  }

  .tab-btn.active {
    color: var(--accent-cyan);
  }

  .tab-btn.active::after {
    content: '';
    position: absolute;
    bottom: -1px; left: 0; right: 0;
    height: 2px;
    background: var(--accent-cyan);
    box-shadow: 0 0 10px var(--accent-cyan);
  }

  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  /* Textarea */
  textarea {
    width: 100%;
    height: 150px;
    background: var(--bg-surface-alt);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    padding: 1rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    resize: vertical;
    transition: var(--transition);
    margin-bottom: 1rem;
  }

  textarea:focus {
    outline: none;
    border-color: var(--accent-cyan);
    box-shadow: 0 0 12px rgba(0, 229, 255, 0.1);
  }

  .input-hint {
    font-size: 0.82rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  /* Drag and Drop Zone */
  .drag-zone {
    border: 2px dashed var(--card-border-hover);
    border-radius: var(--radius-md);
    padding: 2.5rem;
    text-align: center;
    background: rgba(255, 255, 255, 0.01);
    cursor: pointer;
    transition: var(--transition);
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
  }

  .drag-zone:hover, .drag-zone.dragover {
    border-color: var(--accent-cyan);
    background: rgba(0, 229, 255, 0.02);
    box-shadow: inset 0 0 15px rgba(0,229,255,0.02);
  }

  .drag-zone svg {
    stroke: var(--text-secondary);
    transition: var(--transition);
  }

  .drag-zone:hover svg, .drag-zone.dragover svg {
    stroke: var(--accent-cyan);
    transform: scale(1.05);
  }

  .drag-zone p {
    font-size: 0.95rem;
    color: var(--text-secondary);
  }

  .drag-zone p span {
    color: var(--accent-cyan);
    font-weight: 500;
    text-decoration: underline;
  }

  /* Participantes list */
  .list-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .list-header h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
  }

  .counter-badge {
    background: var(--bg-surface-alt);
    border: 1px solid var(--card-border);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.8rem;
    color: var(--accent-cyan);
    font-weight: 600;
  }

  .participants-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2rem;
    min-height: 40px;
    padding: 0.5rem;
    background: rgba(0, 0, 0, 0.2);
    border-radius: var(--radius-md);
    border: 1px solid rgba(255,255,255,0.02);
  }

  .tag-empty {
    color: var(--text-tertiary);
    font-size: 0.88rem;
    font-style: italic;
    margin: auto;
  }

  :global(.participant-tag) {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--bg-surface-alt);
    border: 1px solid var(--card-border);
    color: var(--text-primary);
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    font-size: 0.85rem;
    animation: popIn 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    transition: var(--transition);
  }

  :global(.participant-tag:hover) {
    border-color: rgba(255, 77, 106, 0.3);
    background: rgba(255, 77, 106, 0.05);
  }

  :global(.participant-tag .tag-remove) {
    cursor: pointer;
    color: var(--text-tertiary);
    font-size: 1.1rem;
    line-height: 1;
    display: flex;
    align-items: center;
    transition: var(--transition);
  }

  :global(.participant-tag:hover .tag-remove) {
    color: var(--accent-danger);
  }

  /* Matriz de Validación Anónima */
  .validation-section {
    margin-top: 2.5rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px dashed var(--card-border-hover);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    display: none;
  }

  .validation-section.show {
    display: block;
    animation: fadeIn 0.5s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .validation-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--accent-cyan);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .validation-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 1.2rem;
    line-height: 1.5;
  }

  .matrix-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    text-align: center;
  }

  .matrix-table th {
    color: var(--text-secondary);
    font-weight: 600;
    padding: 0.6rem;
    border-bottom: 1px solid var(--card-border);
  }

  .matrix-table td {
    padding: 0.8rem 0.6rem;
    border-bottom: 1px solid rgba(255,255,255,0.02);
  }

  .matrix-arrow {
    color: var(--accent-purple);
    font-weight: bold;
  }

  /* Resultados Sorteo */
  .results-section {
    margin-top: 3rem;
    display: none;
  }

  .results-section.show {
    display: block;
  }

  .results-section h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.6rem;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .links-list {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  :global(.link-row) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--bg-surface-alt);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-md);
    padding: 1rem 1.5rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  :global(.row-info) {
    flex: 1;
    min-width: 150px;
  }

  :global(.row-name) {
    font-weight: 600;
    font-size: 1.05rem;
    color: #ffffff;
  }

  :global(.row-contact) {
    font-size: 0.82rem;
    color: var(--text-tertiary);
  }

  :global(.row-actions) {
    display: flex;
    gap: 0.5rem;
  }

  :global(.btn-action) {
    background: var(--bg-surface-hover);
    border: 1px solid var(--card-border-hover);
    color: var(--text-primary);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: var(--transition);
  }

  :global(.btn-action:hover) {
    border-color: var(--accent-cyan);
    background: rgba(0, 229, 255, 0.05);
    color: #ffffff;
  }

  :global(.btn-action.btn-wa) {
    border-color: rgba(57, 255, 20, 0.3);
    background: rgba(57, 255, 20, 0.02);
  }

  :global(.btn-action.btn-wa:hover) {
    border-color: var(--accent-success);
    background: rgba(57, 255, 20, 0.08);
    color: #ffffff;
  }

  /* Animación del Regalo 3D */
  .invite-box h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.8rem;
    margin-bottom: 0.75rem;
  }

  .invite-box p {
    color: var(--text-secondary);
    font-size: 1rem;
    margin-bottom: 2rem;
    max-width: 400px;
  }

  .gift-container {
    position: relative;
    width: 200px;
    height: 200px;
    margin: 3rem auto;
    cursor: pointer;
    perspective: 1000px;
  }

  .gift-box {
    width: 100%;
    height: 100%;
    position: absolute;
    transform-style: preserve-3d;
    transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .gift-box:hover {
    transform: scale(1.05) rotateY(10deg);
  }

  .gift-lid {
    position: absolute;
    top: 0; left: -5px;
    width: 210px;
    height: 40px;
    background: linear-gradient(135deg, #ff3366 0%, #e6005c 100%);
    border-radius: 4px;
    z-index: 10;
    transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.5s;
    box-shadow: 0 4px 8px rgba(0,0,0,0.3);
  }

  .gift-body {
    position: absolute;
    top: 38px; left: 0;
    width: 200px;
    height: 162px;
    background: linear-gradient(135deg, #cc004e 0%, #99003a 100%);
    border-radius: 0 0 8px 8px;
    z-index: 5;
    box-shadow: 0 10px 20px rgba(0,0,0,0.4);
  }

  .gift-ribbon-v {
    position: absolute;
    top: 0; left: 90px;
    width: 20px;
    height: 100%;
    background: #ffcc00;
    z-index: 6;
    box-shadow: inset 0 0 5px rgba(0,0,0,0.1);
  }

  .gift-ribbon-h {
    position: absolute;
    top: 70px; left: 0;
    width: 100%;
    height: 20px;
    background: #ffcc00;
    z-index: 6;
    box-shadow: inset 0 0 5px rgba(0,0,0,0.1);
  }

  /* Moño del regalo */
  .gift-bow {
    position: absolute;
    top: -20px; left: 75px;
    width: 50px;
    height: 20px;
