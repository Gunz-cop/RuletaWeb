---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import AdSlot from '../../components/AdSlot.astro';

const posts = await getCollection('blog');
// Sort posts by date descending
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Blog de Decisiones y Sorteos — Artículos y Guías | Decídelo.app';
const description = 'Encuentra guías completas, consejos de probabilidad y dinámicas para organizar sorteos justos, juegos de mesa y tomar mejores decisiones al azar.';
const keywords = 'blog de decisiones, sorteos online, como hacer sorteos, ruleta de nombres, amigo secreto guia, probabilidad de lanzar moneda';

const schemaLD = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Blog",
      "@id": "https://decidelo.app/blog#blog",
      "name": "Blog de Decisiones y Sorteos — Decídelo.app",
      "description": description,
      "url": "https://decidelo.app/blog",
      "publisher": {
        "@type": "Organization",
        "name": "Decídelo.app",
        "logo": {
          "@type": "ImageObject",
          "url": "https://decidelo.app/favicon.svg"
        },
        "url": "https://decidelo.app/"
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://decidelo.app/blog#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": "https://decidelo.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Blog",
          "item": "https://decidelo.app/blog"
        }
      ]
    }
  ]
};
---

<Layout title={title} description={description} keywords={keywords} schemaLD={schemaLD} showHomeHeader={false}>
  <main class="container">
    
    <!-- Hero Section -->
    <section class="hero slide-up delay-1">
      <h1>Blog de <span class="gradient-text">Decisiones</span></h1>
      <p>Aprende a organizar sorteos, dinámicas de grupo, juegos y descubre la ciencia detrás de la probabilidad y la toma de decisiones.</p>
    </section>

    <AdSlot position="top" />

    <!-- Articles Grid -->
    <section class="blog-section slide-up delay-2" aria-label="Listado de artículos del blog">
      {sortedPosts.length === 0 ? (
        <div class="no-posts-card">
          <p>Próximamente publicaremos nuestros primeros artículos. ¡Mantente al tanto!</p>
        </div>
      ) : (
        <>
          <!-- Post Destacado -->
          {(() => {
            const featuredPost = sortedPosts[0];
            const formattedDate = new Date(featuredPost.data.pubDate).toLocaleDateString('es-ES', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            });
            const words = featuredPost.body ? featuredPost.body.split(/\s+/).length : 0;
            const readingTime = Math.max(1, Math.round(words / 200));

            return (
              <article class="featured-post-card token-grid-card">
                <a href={`/blog/${featuredPost.id}`} class="featured-post-link">
                  {featuredPost.data.heroImage && (
                    <div class="featured-post-image">
                      <img src={featuredPost.data.heroImage} alt={featuredPost.data.title} loading="eager" />
                    </div>
                  )}
                  <div class="featured-post-content">
                    <div class="featured-badge">🔥 Destacado</div>
                    <h2 class="featured-post-title">{featuredPost.data.title}</h2>
                    <p class="featured-post-desc">{featuredPost.data.description}</p>
                    <div class="blog-card-meta">
                      <time datetime={featuredPost.data.pubDate.toISOString()}>{formattedDate}</time>
                      <span class="bullet">•</span>
                      <span>⏱️ {readingTime} min de lectura</span>
                    </div>
                    <div class="blog-card-tags">
                      {featuredPost.data.tags.map(tag => (
                        <span class="tag-badge">#{tag}</span>
                      ))}
                    </div>
                    <span class="read-more-btn">
                      Leer artículo 
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                      </svg>
                    </span>
                  </div>
                </a>
              </article>
            );
          })()}

          <!-- Título sección recientes -->
          {sortedPosts.length > 1 && (
            <div class="recents-header">
              <h2 class="recents-title">Artículos Recientes</h2>
            </div>
            
            <div class="blog-grid">
              {sortedPosts.slice(1).map((post, index) => {
                const formattedDate = new Date(post.data.pubDate).toLocaleDateString('es-ES', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                });
                const words = post.body ? post.body.split(/\s+/).length : 0;
                const readingTime = Math.max(1, Math.round(words / 200));
                const delayClass = `reveal-delay-${(index % 4) + 1}`;

                return (
                  <article class={`blog-card token-grid-card reveal-scale ${delayClass}`}>
                    <a href={`/blog/${post.id}`} class="blog-card-link">
                      {post.data.heroImage && (
                        <div class="blog-card-image">
                          <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
                        </div>
                      )}
                      <div class="blog-card-content">
                        <div class="blog-card-meta">
                          <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
                          <span class="bullet">•</span>
                          <span>⏱️ {readingTime} min</span>
                        </div>
                        <h2 class="blog-card-title">{post.data.title}</h2>
                        <p class="blog-card-desc">{post.data.description}</p>
                        <div class="blog-card-tags">
                          {post.data.tags.map(tag => (
                            <span class="tag-badge">#{tag}</span>
                          ))}
                        </div>
                        <span class="read-more-btn">
                          Leer artículo 
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                          </svg>
                        </span>
                      </div>
                    </a>
                  </article>
                );
              })}
            </div>
          )}
        </>
      )}
    </section>

    <AdSlot position="bottom" />

  </main>
</Layout>

<style>
  main {
    padding: 3rem 0;
  }

  .blog-section {
    width: 100%;
    margin-top: 1.5rem;
  }

  .no-posts-card {
    background: var(--bg-surface);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-lg);
    padding: 3rem;
    text-align: center;
    color: var(--text-secondary);
  }

  /* Featured Post Card */
  .featured-post-card {
    background: var(--bg-surface);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    margin-bottom: 3.5rem;
    position: relative;
  }

  .featured-post-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: var(--accent-gradient);
  }

  .featured-post-link {
    text-decoration: none;
    color: inherit;
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 860px) {
    .featured-post-link {
      grid-template-columns: 1.2fr 0.8fr;
    }
  }

  .featured-post-image {
    width: 100%;
    height: 240px;
    overflow: hidden;
    border-bottom: 1px solid var(--card-border);
  }

  @media (min-width: 860px) {
    .featured-post-image {
      height: 100%;
      min-height: 380px;
      border-bottom: none;
      border-right: 1px solid var(--card-border);
    }
  }

  .featured-post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .featured-post-card:hover .featured-post-image img {
    transform: scale(1.03);
  }

  .featured-post-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.85rem;
  }

  @media (min-width: 860px) {
    .featured-post-content {
      padding: 3rem;
    }
  }

  .featured-badge {
    align-self: flex-start;
    font-family: 'Outfit', sans-serif;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--accent-coral);
    background: rgba(255, 94, 98, 0.1);
    border: 1px solid rgba(255, 94, 98, 0.2);
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
  }

  .featured-post-title {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(1.5rem, 4vw, 2.1rem);
    font-weight: 800;
    line-height: 1.2;
    color: #ffffff;
    margin: 0;
    transition: var(--transition);
  }

  .featured-post-card:hover .featured-post-title {
    color: var(--accent-coral);
  }

  .featured-post-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  /* Recent Posts Section */
  .recents-header {
    border-bottom: 1.5px solid rgba(255, 255, 255, 0.04);
    margin-bottom: 2rem;
    padding-bottom: 0.5rem;
  }

  .recents-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2rem;
    width: 100%;
  }

  .blog-card {
    background: var(--bg-surface);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.35s ease,
                box-shadow 0.35s ease;
  }

  .blog-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3.5px;
    background: var(--accent-gradient);
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .blog-card:hover::before {
    opacity: 1;
  }

  .blog-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    height: 100%;
  }

  .blog-card-content {
    padding: 2.2rem 2rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 0.8rem;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--text-secondary);
  }

  .bullet {
    color: rgba(255, 255, 255, 0.08);
  }

  .blog-card-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.3;
    color: #ffffff;
    margin: 0;
    transition: var(--transition);
  }

  .blog-card:hover .blog-card-title {
    color: var(--accent-mint);
  }

  .blog-card:nth-child(even):hover .blog-card-title {
    color: var(--accent-purple);
  }

  .blog-card-desc {
    color: var(--text-secondary);
    font-size: 0.88rem;
    line-height: 1.5;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin: 0.4rem 0;
  }

  .tag-badge {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--accent-mint);
    background: rgba(0, 242, 254, 0.06);
    border: 1px solid rgba(0, 242, 254, 0.1);
    padding: 0.15rem 0.5rem;
    border-radius: 99px;
  }

  .blog-card:nth-child(even) .tag-badge {
    color: var(--accent-purple);
    background: rgba(179, 102, 255, 0.06);
    border-color: rgba(179, 102, 255, 0.1);
  }

  .blog-card:nth-child(3n+1) .tag-badge {
    color: var(--accent-coral);
    background: rgba(255, 94, 98, 0.06);
    border-color: rgba(255, 94, 98, 0.1);
  }

  .read-more-btn {
    font-family: 'Outfit', sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text-primary);
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.6rem;
    transition: var(--transition);
  }

  .read-more-btn svg {
    transition: transform 0.25s ease;
  }

  .blog-card:hover .read-more-btn {
    color: var(--accent-mint);
  }

  .featured-post-card:hover .read-more-btn {
    color: var(--accent-coral);
  }

  .blog-card:hover .read-more-btn svg,
  .featured-post-card:hover .read-more-btn svg {
    transform: translateX(3px);
  }

  .blog-card-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
    border-bottom: 1px solid var(--card-border);
    position: relative;
  }

  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .blog-card:hover .blog-card-image img {
    transform: scale(1.05);
  }

  /* Responsive overrides */
  @media (max-width: 480px) {
    .blog-card-content,
    .featured-post-content {
      padding: 1.5rem;
    }
    .blog-card-image {
      height: 160px;
    }
    .featured-post-image {
      height: 180px;
    }
  }
</style>
