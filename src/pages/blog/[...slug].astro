---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { adsenseReadySet } from '../../data/adsenseEditorial';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const words = post.body ? post.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.round(words / 200));
const indexable = post.data.indexable || adsenseReadySet.has(post.id);
const { Content } = await render(post);
---

<BlogPost {...post.data} slug={post.id} indexable={indexable} readingTime={readingTime}>
  <Content />
</BlogPost>
