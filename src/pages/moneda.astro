---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import HubGrid from '../components/HubGrid.astro';
import SeoArticle from '../components/SeoArticle.astro';

const title = 'Lanzar Moneda Online — Cara o Cruz 3D Gratis | Decídelo.app';
const description = 'Lanza una moneda virtual en 3D con físicas de giro realistas. Elige entre moneda clásica dorada, antigua de pirata o forajida con agujero de bala calado. Sin anuncios molestos.';
const keywords = 'lanzar moneda, cara o cruz, moneda virtual 3d, azar, tomar decisiones, moneda online, cara cruz, decidir al azar';

const schemaLD = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "@id": "https://decidelo.app/moneda#webapp",
      "name": "Lanzar Moneda Online — Decídelo.app",
      "description": "Herramienta online e independiente para simular el lanzamiento de una moneda 3D (Cara o Cruz) con físicas de desaceleración y múltiples aspectos visuales.",
      "url": "https://decidelo.app/moneda",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript and HTML5 3D Transforms",
      "softwareVersion": "2.0.0",
      "inLanguage": "es",
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      },
      "image": "https://decidelo.app/blog/moneda.png",
      "screenshot": "https://decidelo.app/blog/moneda.png",
      "publisher": {
        "@type": "Organization",
        "@id": "https://decidelo.app/#organization",
        "name": "Decídelo.app",
        "url": "https://decidelo.app/",
        "logo": {
          "@type": "ImageObject",
          "url": "https://decidelo.app/favicon.svg"
        }
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://decidelo.app/moneda#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": "https://decidelo.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Lanzar Moneda",
          "item": "https://decidelo.app/moneda"
        }
      ]
    }
  ]
};
