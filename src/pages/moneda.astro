---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import HubGrid from '../components/HubGrid.astro';
import SeoArticle from '../components/SeoArticle.astro';

const title = 'Cara o Cruz Online — Lanzar Moneda Gratis | Decídelo.app';
const description = 'Lanza una moneda online para decidir entre cara o cruz, cara o sello, sí o no, turnos o pequeños dilemas. Gratis, rápido, sin registro y con historial.';
const keywords = 'cara o cruz online, lanzar moneda, tirar moneda, tira una moneda, cara o sello, moneda online, moneda virtual, lanzar una moneda, volado online';

const schemaLD = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "@id": "https://decidelo.app/moneda#webapp",
      "name": "Lanzar Moneda Online — Decídelo.app",
      "description": "Herramienta online para lanzar una moneda y decidir entre cara o cruz, cara o sello o dos opciones equivalentes. Gratis, sin registro y con historial local.",
      "url": "https://decidelo.app/moneda",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript and HTML5 3D Transforms",
      "softwareVersion": "2.0.0",
      "inLanguage": "es",
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      },
      "image": "https://decidelo.app/blog/moneda.png",
      "screenshot": "https://decidelo.app/blog/moneda.png",
      "publisher": {
        "@type": "Organization",
        "@id": "https://decidelo.app/#organization",
        "name": "Decídelo.app",
        "url": "https://decidelo.app/",
        "logo": {
          "@type": "ImageObject",
          "url": "https://decidelo.app/favicon.svg"
        }
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://decidelo.app/moneda#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cómo lanzar cara o cruz online?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Abre la herramienta, asigna una opción a cara y otra a cruz, pulsa Lanzar y espera el resultado. El historial local muestra los últimos lanzamientos."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cara o sello es lo mismo que cara o cruz?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. En muchos países se dice cara o sello, águila o sol, volado o cara o cruz. La dinámica es la misma: dos resultados posibles con probabilidad equivalente."
          }
        },
        {
          "@type": "Question",
          "name": "¿La moneda online guarda mis resultados?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Solo se guarda un historial breve en tu navegador mediante almacenamiento local. No necesitas cuenta y tus decisiones no se envían a un servidor."
          }
        }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://decidelo.app/moneda#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": "https://decidelo.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Lanzar Moneda",
          "item": "https://decidelo.app/moneda"
        }
      ]
    }
  ]
};
